# ── Required ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-key-here

# ── ChromaDB connection ────────────────────────────────────────────────────────
# Local dev: localhost   |   Docker Compose: chroma
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION=documents

# ── OpenAI models ─────────────────────────────────────────────────────────────
EMBEDDING_MODEL=text-embedding-3-small
CHAT_MODEL=gpt-4o-mini

# ── RAG tuning ─────────────────────────────────────────────────────────────────
TOP_K=4
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# ── Server ─────────────────────────────────────────────────────────────────────
# Comma-separated list of origins the frontend runs on
ALLOWED_ORIGINS=["http://localhost:5173"]
LOG_LEVEL=INFO
